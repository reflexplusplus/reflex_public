@Font Code:
{
	path: "fonts/Roboto_Mono/static/RobotoMono-Regular.ttf";

	size: 24;
};

size: 512,512;

bg_colour: 0;

Display:
{
	render: x4;
	render_pad: 4;
	
	transition: 0.25;
	
	size: 320;
	
	@Float32 width: 4;
	
	bg: ColourCanvas();
	
	@State hover:
	{
		fg: 
		Fill(indent: -4; color: 0,128),
		Blur(radius: 16; content: Text(font: Code; value: &value; justify: center)),
		Text(font: Code; value: &value; justify: center);
	};
};
