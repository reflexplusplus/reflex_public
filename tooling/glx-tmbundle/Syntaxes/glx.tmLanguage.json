{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "glx",
    "scopeName": "source.glx",
    "fileTypes": ["glx"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#directives" },
        { "include": "#at-rules" },
        { "include": "#strings" },
        { "include": "#values" },
        { "include": "#keys" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.glx",
                    "match": "//.*$"
                }
            ]
        },
        "directives": {
            "patterns": [
                {
                    "match": "(#)(option)\\b\\s*([A-Za-z_][A-Za-z0-9_]*)?\\s*([A-Za-z_][A-Za-z0-9_]*)?",
                    "captures": {
                        "1": { "name": "punctuation.definition.directive.glx" },
                        "2": { "name": "keyword.control.directive.glx" },
                        "3": { "name": "variable.parameter.directive.glx" },
                        "4": { "name": "constant.language.directive.glx" }
                    }
                }
            ]
        },
        "at-rules": {
            "patterns": [
                {
                    "match": "(@)(Font|Bitmap|Colour|Color|Alias|State)\\b\\s*([A-Za-z_][A-Za-z0-9_]*)?",
                    "captures": {
                        "1": { "name": "punctuation.definition.keyword.glx" },
                        "2": { "name": "keyword.control.at-rule.glx" },
                        "3": { "name": "entity.name.type.glx" }
                    }
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.glx",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        { "name": "constant.character.escape.glx", "match": "\\\\." }
                    ]
                }
            ]
        },
        "values": {
            "patterns": [
                {
                    "name": "constant.other.color.hex.glx",
                    "match": "\\$[0-9a-fA-F]+"
                },
                {
                    "name": "constant.numeric.glx",
                    "match": "(?<![A-Za-z_])-?[0-9]+(\\.[0-9]+)?\\b"
                },
                {
                    "match": "(&)([A-Za-z_][A-Za-z0-9_]*)",
                    "captures": {
                        "1": { "name": "punctuation.definition.variable.glx" },
                        "2": { "name": "variable.other.reference.glx" }
                    }
                },
                {
                    "match": "([A-Za-z_][A-Za-z0-9_]*)(?=\\()",
                    "captures": {
                        "1": { "name": "support.function.glx" }
                    }
                }
            ]
        },
        "keys": {
            "patterns": [
                {
                    "comment": "Any identifier followed by ':' — covers both block selectors ('Header:', 'PbRow:') and property keys ('size:', 'bg:', 'font:'). Single scope for consistent highlighting across nesting levels including inside function-call arg lists.",
                    "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(?=\\s*:)",
                    "captures": {
                        "1": { "name": "entity.name.tag.glx" }
                    }
                }
            ]
        },
        "punctuation": {
            "patterns": [
                { "name": "punctuation.section.block.begin.glx", "match": "\\{" },
                { "name": "punctuation.section.block.end.glx", "match": "\\}" },
                { "name": "punctuation.terminator.statement.glx", "match": ";" },
                { "name": "punctuation.separator.key-value.glx", "match": ":" },
                { "name": "punctuation.separator.comma.glx", "match": "," }
            ]
        }
    }
}
