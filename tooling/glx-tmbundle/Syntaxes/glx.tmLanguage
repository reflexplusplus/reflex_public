<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>name</key>
	<string>glx</string>
	<key>scopeName</key>
	<string>source.glx</string>
	<key>fileTypes</key>
	<array>
		<string>glx</string>
	</array>
	<key>patterns</key>
	<array>
		<dict>
			<key>include</key>
			<string>#comments</string>
		</dict>
		<dict>
			<key>include</key>
			<string>#directives</string>
		</dict>
		<dict>
			<key>include</key>
			<string>#at-rules</string>
		</dict>
		<dict>
			<key>include</key>
			<string>#strings</string>
		</dict>
		<dict>
			<key>include</key>
			<string>#values</string>
		</dict>
		<dict>
			<key>include</key>
			<string>#keys</string>
		</dict>
		<dict>
			<key>include</key>
			<string>#punctuation</string>
		</dict>
	</array>
	<key>repository</key>
	<dict>
		<key>comments</key>
		<dict>
			<key>patterns</key>
			<array>
				<dict>
					<key>name</key>
					<string>comment.line.double-slash.glx</string>
					<key>match</key>
					<string>//.*$</string>
				</dict>
			</array>
		</dict>
		<key>directives</key>
		<dict>
			<key>patterns</key>
			<array>
				<dict>
					<key>match</key>
					<string>(#)(option)\b\s*([A-Za-z_][A-Za-z0-9_]*)?\s*([A-Za-z_][A-Za-z0-9_]*)?</string>
					<key>captures</key>
					<dict>
						<key>1</key>
						<dict>
							<key>name</key>
							<string>punctuation.definition.directive.glx</string>
						</dict>
						<key>2</key>
						<dict>
							<key>name</key>
							<string>keyword.control.directive.glx</string>
						</dict>
						<key>3</key>
						<dict>
							<key>name</key>
							<string>variable.parameter.directive.glx</string>
						</dict>
						<key>4</key>
						<dict>
							<key>name</key>
							<string>constant.language.directive.glx</string>
						</dict>
					</dict>
				</dict>
			</array>
		</dict>
		<key>at-rules</key>
		<dict>
			<key>patterns</key>
			<array>
				<dict>
					<key>match</key>
					<string>(@)(Font|Bitmap|Colour|Color|Alias|State)\b\s*([A-Za-z_][A-Za-z0-9_]*)?</string>
					<key>captures</key>
					<dict>
						<key>1</key>
						<dict>
							<key>name</key>
							<string>punctuation.definition.keyword.glx</string>
						</dict>
						<key>2</key>
						<dict>
							<key>name</key>
							<string>keyword.control.at-rule.glx</string>
						</dict>
						<key>3</key>
						<dict>
							<key>name</key>
							<string>entity.name.type.glx</string>
						</dict>
					</dict>
				</dict>
			</array>
		</dict>
		<key>strings</key>
		<dict>
			<key>patterns</key>
			<array>
				<dict>
					<key>name</key>
					<string>string.quoted.double.glx</string>
					<key>begin</key>
					<string>"</string>
					<key>end</key>
					<string>"</string>
					<key>patterns</key>
					<array>
						<dict>
							<key>name</key>
							<string>constant.character.escape.glx</string>
							<key>match</key>
							<string>\\.</string>
						</dict>
					</array>
				</dict>
			</array>
		</dict>
		<key>values</key>
		<dict>
			<key>patterns</key>
			<array>
				<dict>
					<key>name</key>
					<string>constant.other.color.hex.glx</string>
					<key>match</key>
					<string>\$[0-9a-fA-F]+</string>
				</dict>
				<dict>
					<key>name</key>
					<string>constant.numeric.glx</string>
					<key>match</key>
					<string>(?&lt;![A-Za-z_])-?[0-9]+(\.[0-9]+)?\b</string>
				</dict>
				<dict>
					<key>match</key>
					<string>(&amp;)([A-Za-z_][A-Za-z0-9_]*)</string>
					<key>captures</key>
					<dict>
						<key>1</key>
						<dict>
							<key>name</key>
							<string>punctuation.definition.variable.glx</string>
						</dict>
						<key>2</key>
						<dict>
							<key>name</key>
							<string>variable.other.reference.glx</string>
						</dict>
					</dict>
				</dict>
				<dict>
					<key>match</key>
					<string>([A-Za-z_][A-Za-z0-9_]*)(?=\()</string>
					<key>captures</key>
					<dict>
						<key>1</key>
						<dict>
							<key>name</key>
							<string>support.function.glx</string>
						</dict>
					</dict>
				</dict>
			</array>
		</dict>
		<key>keys</key>
		<dict>
			<key>patterns</key>
			<array>
				<dict>
					<key>comment</key>
					<string>Any identifier followed by ':' — covers both block selectors ('Header:', 'PbRow:') and property keys ('size:', 'bg:', 'font:'). Single scope for consistent highlighting across nesting levels including inside function-call arg lists.</string>
					<key>match</key>
					<string>\b([A-Za-z_][A-Za-z0-9_]*)(?=\s*:)</string>
					<key>captures</key>
					<dict>
						<key>1</key>
						<dict>
							<key>name</key>
							<string>entity.name.tag.glx</string>
						</dict>
					</dict>
				</dict>
			</array>
		</dict>
		<key>punctuation</key>
		<dict>
			<key>patterns</key>
			<array>
				<dict>
					<key>name</key>
					<string>punctuation.section.block.begin.glx</string>
					<key>match</key>
					<string>\{</string>
				</dict>
				<dict>
					<key>name</key>
					<string>punctuation.section.block.end.glx</string>
					<key>match</key>
					<string>\}</string>
				</dict>
				<dict>
					<key>name</key>
					<string>punctuation.terminator.statement.glx</string>
					<key>match</key>
					<string>;</string>
				</dict>
				<dict>
					<key>name</key>
					<string>punctuation.separator.key-value.glx</string>
					<key>match</key>
					<string>:</string>
				</dict>
				<dict>
					<key>name</key>
					<string>punctuation.separator.comma.glx</string>
					<key>match</key>
					<string>,</string>
				</dict>
			</array>
		</dict>
	</dict>
</dict>
</plist>
